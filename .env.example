# RunPod Serverless — Gemma 4 31B NVFP4 Worker
# Copy to RunPod endpoint env vars or set via console UI
#
# CRITICAL: Do NOT set QUANTIZATION, ATTENTION_BACKEND, or MOE_BACKEND.
# vLLM 0.25+ auto-detects NVFP4 quantization and selects Cute-DSL backend.
# Setting Marlin manually = 2.5× SLOWER (W4A16 instead of W4A4).

# === Required ===
MODEL_NAME=unsoloth/gemma-4-31B-it-NVFP4

# === Core settings ===
DTYPE=auto
MAX_MODEL_LEN=131072
GPU_MEMORY_UTILIZATION=0.90
TENSOR_PARALLEL_SIZE=1
ENFORCE_EAGER=false

# === Concurrency ===
MAX_CONCURRENCY=10
DEFAULT_BATCH_SIZE=50

# === Optional: MTP Speculative Decoding (faster decode, slightly less throughput) ===
# SPECULATIVE_CONFIG={"method": "mtp", "num_speculative_tokens": 2}

# === Optional: HF Token for gated models ===
# HF_TOKEN=hf_your_token_here

# === Cache ===
# HF_HOME is auto-set to /runpod-volume/huggingface-cache/hub in Dockerfile
# HF_HUB_ENABLE_HF_TRANSFER=1
